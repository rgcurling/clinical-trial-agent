# ── Required API keys ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── FastAPI service ────────────────────────────────────────────────────────────
PORT=8000
WORKERS=4
CORS_ORIGINS=*

# ── Optional tuning ────────────────────────────────────────────────────────────
# Maximum trials fetched from ClinicalTrials.gov per request
MAX_TRIALS_TO_RETRIEVE=20
# Maximum trials sent to Claude for matching
MAX_TRIALS_TO_MATCH=10
# Maximum trials returned in /match response
MAX_TRIALS_TO_RETURN=5
